{
  "rules": {
    ".read": false,
    ".write": false,
    "predicacion": {
      ".read": true,
      ".write": true,
      "hermanos": {
        "$id": { ".validate": "newData.hasChildren(['id','nombre'])" }
      },
      "puntos": {
        "$id": { ".validate": "newData.hasChildren(['id','nombre'])" }
      },
      "meses": {
        "$id": { ".validate": "newData.hasChildren(['id'])" }
      },
      "disponibilidad": {
        "$mes": {
          "$hermano": { ".validate": "newData.hasChildren(['hermanoId','mesId'])" }
        }
      },
      "asignaciones": {
        "$mes": {
          "$slot": { ".validate": true }
        }
      },
      "config": {
        ".validate": true,
        "$campo": { ".validate": true }
      },
      "$otro": { ".validate": false }
    }
  }
}
